<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EduChain Certificate Generator</title>

<script src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>

<style>
body{
    font-family: Arial, sans-serif;
    background:#eef4ff;
    text-align:center;
    padding:20px;
}

.container{
    max-width:900px;
    margin:auto;
}

input{
    padding:10px;
    margin:8px;
    width:250px;
}

button{
    padding:10px 16px;
    margin:10px;
    border:none;
    background:#1e40af;
    color:white;
    border-radius:6px;
    cursor:pointer;
}

button:hover{
    background:#1d4ed8;
}

#certificate{
    width:800px;
    margin:30px auto;
    background:white;
    border:12px solid #1e3a8a;
    padding:40px;
    border-radius:18px;
    box-shadow:0 8px 18px rgba(0,0,0,0.15);
}

.title{
    font-size:38px;
    color:#1e3a8a;
    font-weight:bold;
}

.subtitle{
    font-size:18px;
    color:#444;
    margin-top:10px;
}

.name{
    font-size:34px;
    color:#111;
    margin:30px 0;
    font-weight:bold;
}

.small{
    color:#555;
    margin:8px;
}

.footer{
    margin-top:30px;
    display:flex;
    justify-content:space-between;
}
</style>
</head>

<body>

<div class="container">
<h1>EduChain Certificate Generator</h1>

<input type="text" id="studentName" placeholder="Student Name">
<input type="text" id="course" placeholder="Course Name">
<input type="text" id="certid" placeholder="Certificate ID">
<br>
<button onclick="generateCert()">Generate Certificate</button>
<button onclick="downloadCert()">Download Image</button>

<div id="certificate">
<div class="title">Certificate of Achievement</div>
<div class="subtitle">Issued by EduChain Blockchain Verification System</div>

<p class="small">This is to certify that</p>

<div class="name" id="nameView">Student Name</div>

<p class="small">has successfully completed</p>
<h2 id="courseView">Course Name</h2>

<p class="small">Certificate ID: <span id="idView">BC2026EDU001</span></p>
<p class="small">Verified on Blockchain Ledger</p>

<div class="footer">
<div>Authorized Signatory</div>
<div>Date: 2026</div>
</div>

</div>
</div>

<script>
function generateCert(){
document.getElementById("nameView").innerText =
document.getElementById("studentName").value || "Student Name";

document.getElementById("courseView").innerText =
document.getElementById("course").value || "Course Name";

document.getElementById("idView").innerText =
document.getElementById("certid").value || "BC2026EDU001";
}

function downloadCert(){
html2canvas(document.querySelector("#certificate")).then(canvas => {
let link = document.createElement("a");
link.download = "certificate.png";
link.href = canvas.toDataURL();
link.click();
});
}
</script>

</body>
</html>
