<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Blockchain Degree Verification Project</title>

<style>
body{
    font-family: Arial, sans-serif;
    margin:0;
    padding:0;
    background: linear-gradient(to right,#dbeafe,#eff6ff);
}

header{
    background:#1e3a8a;
    color:white;
    text-align:center;
    padding:20px;
}

.container{
    width:90%;
    margin:auto;
    margin-top:20px;
}

.card{
    background:white;
    padding:20px;
    margin-bottom:20px;
    border-radius:12px;
    box-shadow:0 4px 10px rgba(0,0,0,0.1);
}

h2{
    color:#1e3a8a;
}

table{
    width:100%;
    border-collapse:collapse;
    margin-top:15px;
}

table, th, td{
    border:1px solid #ccc;
}

th{
    background:#2563eb;
    color:white;
    padding:10px;
}

td{
    padding:10px;
    text-align:center;
}

input, button{
    padding:10px;
    margin:8px;
    width:90%;
}

button{
    background:#1e40af;
    color:white;
    border:none;
    cursor:pointer;
    border-radius:6px;
}

button:hover{
    background:#1d4ed8;
}

footer{
    text-align:center;
    padding:15px;
    background:#1e3a8a;
    color:white;
}
</style>
</head>

<body>

<header>
<h1>Blockchain Degree Verification System</h1>
<p>Education Sector Project</p>
</header>

<div class="container">

<div class="card">
<h2>Traditional Problems</h2>
<ul>
<li>Slow verification process</li>
<li>High cost</li>
<li>Fake certificates</li>
<li>Manual paperwork</li>
<li>Lack of transparency</li>
</ul>
</div>

<div class="card">
<h2>Improvements Made in Project</h2>
<ul>
<li>Instant digital verification</li>
<li>Secure blockchain records</li>
<li>Reduced fraud risk</li>
<li>Paperless data sharing</li>
<li>High transparency</li>
</ul>
</div>

<div class="card">
<h2>Student Degree Verification</h2>

<input type="text" id="name" placeholder="Enter Student Name">
<input type="text" id="degree" placeholder="Enter Degree Name">
<input type="text" id="year" placeholder="Enter Passing Year">

<button onclick="verify()">Verify Degree</button>

<p id="result"></p>

</div>

<div class="card">
<h2>Comparison Table</h2>

<table>
<tr>
<th>Factor</th>
<th>Traditional</th>
<th>Blockchain</th>
</tr>

<tr>
<td>Time</td>
<td>5 Days</td>
<td>2 Minutes</td>
</tr>

<tr>
<td>Cost</td>
<td>₹500</td>
<td>Low</td>
</tr>

<tr>
<td>Fraud Risk</td>
<td>High</td>
<td>Low</td>
</tr>

<tr>
<td>Trust</td>
<td>Medium</td>
<td>High</td>
</tr>

</table>
</div>

</div>

<footer>
Project by Bhumi Sachdeva
</footer>

<script>
function verify(){
let name=document.getElementById("name").value;
let degree=document.getElementById("degree").value;
let year=document.getElementById("year").value;

if(name && degree && year){
document.getElementById("result").innerHTML=
"✅ Degree Verified Successfully for " + name;
}
else{
document.getElementById("result").innerHTML=
"⚠ Please fill all details.";
}
}
</script>

</body>
</html>
